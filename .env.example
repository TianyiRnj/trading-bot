MUSASHI_API_BASE_URL=https://musashi-api.vercel.app
BOT_MODE=paper
BOT_SCAN_INTERVAL_SECONDS=60
BOT_MIN_CONFIDENCE=0.76
BOT_MIN_EDGE=0.05
BOT_MIN_VOLUME_24H=20000
BOT_MAX_PRICE=0.85
BOT_MIN_PRICE=0.08
BOT_BANKROLL_USD=10
BOT_MAX_POSITION_USD=3
BOT_MAX_TOTAL_EXPOSURE_USD=10
BOT_LIMIT_ONE_POSITION_PER_EVENT=true
BOT_TAKE_PROFIT_PCT=0.18
BOT_STOP_LOSS_PCT=0.10
BOT_MAX_HOLD_MINUTES=240
BOT_EXIT_ON_SIGNAL_REVERSAL=true
BOT_EXIT_ORDER_TIMEOUT_SECONDS=120
BOT_EXIT_ORDER_REPRICE=true
BOT_STARTUP_RECONCILE=true
BOT_PAPER_GEO_STRICT=false
BOT_RUN_LABEL=default

# Optional musashi-infra Supabase market intelligence (read-only)
BOT_ENABLE_INFRA_ARBITRAGE_FALLBACK=true
BOT_INFRA_MAX_SNAPSHOT_AGE_MINUTES=180
MUSASHI_INFRA_SUPABASE_URL=
MUSASHI_INFRA_SUPABASE_KEY=
MUSASHI_INFRA_TIMEOUT_SECONDS=10

# Postgres storage (required — the bot writes all runtime state to Postgres)
DATABASE_URL=postgresql://musashi:musashi_dev_password@127.0.0.1:5432/musashi_trading_bot
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=musashi_trading_bot
POSTGRES_USER=musashi
POSTGRES_PASSWORD=musashi_dev_password
POSTGRES_SSLMODE=disable
POSTGRES_POOL_MIN=1
POSTGRES_POOL_MAX=5
POSTGRES_CONNECT_TIMEOUT_SECONDS=10

# Arbitrage scanner (simulation only — no live Kalshi execution is implemented)
# Disabled by default. Enable only to run the cross-platform spread scanner.
BOT_ENABLE_ARBITRAGE=false
BOT_ARB_SCAN_INTERVAL_SECONDS=30

# Polymarket live trading
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137
POLYMARKET_PRIVATE_KEY=
POLYMARKET_SIGNATURE_TYPE=2
POLYMARKET_FUNDER=
